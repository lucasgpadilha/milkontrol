generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────

// Enum para definir a autorização global no sistema SaaS.
enum Role {
  ADMIN
  USER
}

enum PapelFazenda {
  PROPRIETARIO
  GERENTE
  OPERADOR
  VETERINARIO
}

model User {
  id              String    @id @default(cuid())
  nome            String
  email           String    @unique
  senha           String
  role            Role      @default(USER)
  fazendaAtivaId  String?
  fazendaAtiva    Fazenda?  @relation("FazendaAtiva", fields: [fazendaAtivaId], references: [id])
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
  fazendas        UsuarioFazenda[]
  apiKeys         ApiKey[]
}

model UsuarioFazenda {
  id         String   @id @default(cuid())
  userId     String
  fazendaId  String
  papel      PapelFazenda @default(OPERADOR)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fazenda    Fazenda  @relation(fields: [fazendaId], references: [id], onDelete: Cascade)

  @@unique([userId, fazendaId])
}

model ConviteFazenda {
  id        String       @id @default(cuid())
  email     String
  papel     PapelFazenda
  fazendaId String
  fazenda   Fazenda      @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  token     String       @unique
  expiraEm  DateTime
  criadoEm  DateTime     @default(now())

  @@unique([email, fazendaId])
}

// ─── Banco de Sêmen ────────────────────────────────────────────────

model BancoSemen {
  id              String         @id @default(cuid())
  codigo          String
  nomeTouro       String
  raca            String?
  fornecedor      String?
  origem          String?
  quantidade      Int            @default(0)
  fazendaId       String
  fazenda         Fazenda        @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  inseminacoes    Inseminacao[]
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@index([fazendaId])
}

// ─── Veterinários ───────────────────────────────────────────────────

model Veterinario {
  id              String    @id @default(cuid())
  nome            String
  crmv            String?   // Registro no CRMV (ex: CRMV-PR 12345)
  especialidade   String?   // Ex: Reprodução, Clínica, Cirurgia
  telefone        String?
  email           String?
  ativo           Boolean   @default(true)
  fazendaId       String
  fazenda         Fazenda   @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
  inseminacoes    Inseminacao[]
  registrosSanitarios RegistroSanitario[]
  mastites        RegistroMastite[]

  @@index([fazendaId])
}

// ─── Fazenda ─────────────────────────────────────────────────────────

model Fazenda {
  id            String    @id @default(cuid())
  nome          String
  endereco      String?
  cidade        String?
  estado        String?
  ordenhasDia   Int       @default(2)  // 2 ou 3 ordenhas por dia
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  usuarios      UsuarioFazenda[]
  bovinos       Bovino[]
  tanques       Tanque[]
  piquetes      Piquete[]
  veterinarios  Veterinario[]
  estoqueSemen  BancoSemen[]
  registrosAlimentacao RegistroAlimentacao[]
  analises       AnaliseLeite[]
  eventos        AgendaEvento[]
  partos         Parto[]
  estoqueInsumos EstoqueInsumo[]
  protocolosIatf ProtocoloIatf[]
  lotesIatf      LoteIatf[]
  usuariosAtivos User[]   @relation("FazendaAtiva")
  apiKeys        ApiKey[]
  convites       ConviteFazenda[]
}

// ─── API Keys ───────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  nome        String                          // "App do Laticínio", "Balança IoT"
  key         String    @unique               // hash SHA-256 da chave
  prefixo     String                          // primeiros 8 chars "mk_ab12..."
  fazendaId   String
  fazenda     Fazenda   @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  scopes      String[]  @default(["read"])    // ["read", "write", "delete"]
  ativo       Boolean   @default(true)
  ultimoUso   DateTime?
  criadoEm    DateTime  @default(now())
  expiraEm    DateTime?                       // null = sem expiração

  @@index([key])
  @@index([fazendaId])
}

// ─── Piquetes ───────────────────────────────────────────────────────

model Piquete {
  id            String    @id @default(cuid())
  nome          String
  descricao     String?
  fazendaId     String
  fazenda       Fazenda   @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  bovinos       Bovino[]
  registrosAlimentacao RegistroAlimentacao[]
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@unique([nome, fazendaId])
}

// ─── Bovinos ─────────────────────────────────────────────────────────

enum Sexo {
  MACHO
  FEMEA
}

enum SituacaoBovino {
  ATIVA
  VENDIDA
  MORTA
}

model Bovino {
  id              String          @id @default(cuid())
  brinco          String
  nome            String?
  raca            String
  dataNascimento  DateTime
  sexo            Sexo
  situacao        SituacaoBovino  @default(ATIVA)
  foto            String?
  observacoes     String?
  fazendaId       String
  fazenda         Fazenda         @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  piqueteId       String?
  piquete         Piquete?        @relation(fields: [piqueteId], references: [id], onDelete: SetNull)
  maeId           String?
  mae             Bovino?         @relation("MaeFilho", fields: [maeId], references: [id])
  filhos          Bovino[]        @relation("MaeFilho")
  paiInfo         String?         // Nome do touro / código do sêmen
  producoes       ProducaoLeite[]
  lactacoes       Lactacao[]
  inseminacoes    Inseminacao[]
  registrosSanitarios RegistroSanitario[]
  pesagens        Pesagem[]
  mastites        RegistroMastite[]
  eventos         AgendaEvento[]
  partos          Parto[]         @relation("Mae")
  nascimento      Parto?          @relation("Bezerro")
  lotesIatf       AnimalLoteIatf[]
  ecc             Float?
  eccData         DateTime?
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt
  deletedAt       DateTime?       // Soft delete field

  @@unique([brinco, fazendaId])
}

// ─── Pesagem ─────────────────────────────────────────────────────────

model Pesagem {
  id          String   @id @default(cuid())
  data        DateTime
  pesoKg      Float
  bovinoId    String
  bovino      Bovino   @relation(fields: [bovinoId], references: [id], onDelete: Cascade)
  observacoes String?
  criadoEm    DateTime @default(now())

  @@index([bovinoId, data])
}

// ─── Produção de Leite ───────────────────────────────────────────────

enum Turno {
  MANHA
  TARDE
  NOITE     // Apenas para fazendas com 3 ordenhas
}

model ProducaoLeite {
  id          String   @id @default(cuid())
  data        DateTime
  quantidade  Float    // litros
  turno       Turno?
  bovinoId    String
  bovino      Bovino   @relation(fields: [bovinoId], references: [id], onDelete: Cascade)
  criadoEm    DateTime @default(now())

  @@index([bovinoId, data])
}

// ─── Lactação ────────────────────────────────────────────────────────

model Lactacao {
  id          String    @id @default(cuid())
  inicio      DateTime
  fim         DateTime?
  bovinoId    String
  bovino      Bovino    @relation(fields: [bovinoId], references: [id], onDelete: Cascade)
  criadoEm    DateTime  @default(now())

  @@index([bovinoId])
}

// ─── Reprodução ──────────────────────────────────────────────────────

enum TipoInseminacao {
  NATURAL
  ARTIFICIAL
}

model Inseminacao {
  id              String           @id @default(cuid())
  data            DateTime
  tipo            TipoInseminacao
  responsavel     String
  touroSemen      String?          // Identificação do touro ou sêmen
  prenhez         Boolean?
  dataDiagnostico DateTime?
  dataPartoPrevisto DateTime?
  observacoes     String?
  bovinoId        String
  bovino          Bovino           @relation(fields: [bovinoId], references: [id], onDelete: Cascade)
  veterinarioId   String?
  veterinario     Veterinario?     @relation(fields: [veterinarioId], references: [id], onDelete: SetNull)
  bancoSemenId    String?
  bancoSemen      BancoSemen?      @relation(fields: [bancoSemenId], references: [id], onDelete: SetNull)
  criadoEm        DateTime         @default(now())

  @@index([bovinoId])
}

// ─── Tanque de Leite ─────────────────────────────────────────────────

model Tanque {
  id              String               @id @default(cuid())
  nome            String
  capacidadeMax   Float                // litros
  volumeAtual     Float                @default(0)
  fazendaId       String
  fazenda         Fazenda              @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  movimentacoes   MovimentacaoTanque[]
  criadoEm        DateTime             @default(now())
  atualizadoEm    DateTime             @updatedAt
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
}

enum TipoSaida {
  VENDA
  CONSUMO_INTERNO
  DESCARTE
}

model MovimentacaoTanque {
  id          String            @id @default(cuid())
  data        DateTime
  tipo        TipoMovimentacao
  tipoSaida   TipoSaida?       // Apenas quando tipo = SAIDA
  quantidade  Float             // litros
  comprador   String?           // Ex: Laticínio XYZ (Apenas quando tipoSaida = VENDA)
  precoLitro  Float?            // R$ por Litro (Apenas quando tipoSaida = VENDA)
  tanqueId    String
  tanque      Tanque            @relation(fields: [tanqueId], references: [id], onDelete: Cascade)
  criadoEm    DateTime          @default(now())

  @@index([tanqueId, data])
}

// ─── Controle Sanitário ──────────────────────────────────────────────

enum TipoRegistroSanitario {
  VACINA
  VERMIFUGO
  MEDICAMENTO
  TRATAMENTO
}

model RegistroSanitario {
  id              String                 @id @default(cuid())
  data            DateTime
  tipo            TipoRegistroSanitario
  produto         String                 // Nome do medicamento/vacina
  dose            String?
  responsavel     String?
  diasCarencia    Int                    @default(0) // Dias de carência do leite
  fimCarencia     DateTime?              // Data calculada: data + diasCarencia
  observacoes     String?
  bovinoId        String
  bovino          Bovino                 @relation(fields: [bovinoId], references: [id], onDelete: Cascade)
  veterinarioId   String?
  veterinario     Veterinario?           @relation(fields: [veterinarioId], references: [id], onDelete: SetNull)
  insumoId        String?
  insumo          EstoqueInsumo?         @relation(fields: [insumoId], references: [id], onDelete: SetNull)
  criadoEm        DateTime               @default(now())

  @@index([bovinoId])
}

// ─── Alimentação ─────────────────────────────────────────────────────

enum TipoAlimento {
  SILAGEM
  RACAO
  FENO
  SAL_MINERAL
  CONCENTRADO
  PASTO
  OUTRO
}

model RegistroAlimentacao {
  id              String        @id @default(cuid())
  data            DateTime
  tipoAlimento    TipoAlimento
  descricao       String?       // Ex: "Silagem de milho safra 2026"
  quantidadeKg    Float         // Kg por cabeça/dia
  custoUnitario   Float?        // R$ por Kg (opcional, para cálculo futuro)
  piqueteId       String
  piquete         Piquete       @relation(fields: [piqueteId], references: [id], onDelete: Cascade)
  fazendaId       String
  fazenda         Fazenda       @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  observacoes     String?
  criadoEm        DateTime      @default(now())

  @@index([fazendaId, data])
  @@index([piqueteId])
}

// ─── Qualidade do Leite e Mastite ──────────────────────────────────────

model AnaliseLeite {
  id         String   @id @default(cuid())
  data       DateTime
  ccs        Float    // Contagem de Células Somáticas (1000 cel/mL)
  cpp        Float    // Contagem Padrão em Placas (UFC/mL)
  gordura    Float?   // % Gordura (opcional)
  proteina   Float?   // % Proteína (opcional)
  esnf       Float?   // Extrato Seco Desengordurado (opcional)
  laboratorio String? // Nome do laboratório RBQL
  fazendaId  String
  fazenda    Fazenda  @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  criadoEm   DateTime @default(now())

  @@index([fazendaId, data])
}

enum QuartoMamario {
  AD
  AE
  PD
  PE
}

enum TipoMastite {
  CLINICA
  SUBCLINICA
}

model RegistroMastite {
  id          String         @id @default(cuid())
  data        DateTime
  tipo        TipoMastite
  quarto      QuartoMamario
  resultado   String?        // CMT +/++/+++ ou cultivo bacteriano
  tratamento  String?        // Produto/protocolo utilizado
  diasTratamento Int?
  cura        Boolean?       // Confirmação de cura
  dataCura    DateTime?
  observacoes String?
  bovinoId    String
  bovino      Bovino         @relation(fields: [bovinoId], references: [id], onDelete: Cascade)
  veterinarioId String?
  veterinario   Veterinario? @relation(fields: [veterinarioId], references: [id], onDelete: SetNull)
  criadoEm      DateTime      @default(now())

  @@index([bovinoId, data])
}

// ─── Agenda e Partos ───────────────────────────────────────────────────

enum TipoEvento {
  DIAGNOSTICO_PRENHEZ
  VACINACAO_PROGRAMADA
  RETORNO_CARENCIA
  SECAGEM_PREVISTA
  PARTO_PREVISTO
  REVISAO_EQUIPAMENTO
  IATF_ETAPA
  OUTRO
}

enum Prioridade {
  ALTA
  MEDIA
  BAIXA
}

model AgendaEvento {
  id            String        @id @default(cuid())
  titulo        String
  tipo          TipoEvento
  dataHora      DateTime
  concluido     Boolean       @default(false)
  dataConclusao DateTime?
  prioridade    Prioridade    @default(MEDIA)
  notas         String?
  bovinoId      String?
  bovino        Bovino?       @relation(fields: [bovinoId], references: [id], onDelete: Cascade)
  fazendaId     String
  fazenda       Fazenda       @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  criadoEm      DateTime      @default(now())

  @@index([fazendaId, dataHora])
  @@index([bovinoId])
}

enum TipoParto {
  NORMAL
  DISTOCICO
  CESAREA
  ABORTO
  NATIMORTO
}

model Parto {
  id              String     @id @default(cuid())
  data            DateTime
  tipoParto       TipoParto
  pesoBezerroKg   Float?
  sexoBezerro     Sexo?
  colostroFornecido Boolean  @default(false)
  gemelar         Boolean    @default(false)
  observacoes     String?
  bovinoId        String
  bovino          Bovino     @relation("Mae", fields: [bovinoId], references: [id], onDelete: Cascade)
  bezerroId       String?    @unique
  bezerro         Bovino?    @relation("Bezerro", fields: [bezerroId], references: [id], onDelete: SetNull)
  fazendaId       String
  fazenda         Fazenda    @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  criadoEm        DateTime   @default(now())

  @@index([bovinoId])
  @@index([fazendaId, data])
}

// ─── Estoque de Insumos ──────────────────────────────────────────────────

enum TipoInsumo {
  MEDICAMENTO
  VACINA
  SUPLEMENTO
  OUTRO
}

model EstoqueInsumo {
  id              String         @id @default(cuid())
  nome            String
  tipo            TipoInsumo
  quantidade      Float          @default(0)
  unidade         String         // mL, Doses, Kg, etc.
  estoqueMinimo   Float          @default(0)
  observacoes     String?
  fazendaId       String
  fazenda         Fazenda        @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  movimentacoes   MovimentacaoEstoque[]
  usosSanitarios  RegistroSanitario[]
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@index([fazendaId])
}

model MovimentacaoEstoque {
  id            String         @id @default(cuid())
  tipo          TipoMovimentacao
  quantidade    Float
  motivo        String?        // Compra, Aplicação, Descarte
  insumoId      String
  insumo        EstoqueInsumo  @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  usuarioId     String?        // Quem registrou (opcional)
  data          DateTime       @default(now())

  @@index([insumoId])
}

// ─── IATF (Inseminação Artificial em Tempo Fixo) ─────────────────────────

model ProtocoloIatf {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  fazendaId   String?  // null se for um template global
  fazenda     Fazenda? @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  etapas      EtapaIatf[]
  lotes       LoteIatf[]
  criadoEm    DateTime @default(now())
}

model EtapaIatf {
  id            String   @id @default(cuid())
  dia           Int
  titulo        String
  descricao     String?
  protocoloId   String
  protocolo     ProtocoloIatf @relation(fields: [protocoloId], references: [id], onDelete: Cascade)
}

model LoteIatf {
  id            String   @id @default(cuid())
  nome          String
  dataInicio    DateTime
  protocoloId   String
  protocolo     ProtocoloIatf @relation(fields: [protocoloId], references: [id])
  fazendaId     String
  fazenda       Fazenda  @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  animais       AnimalLoteIatf[]
  criadoEm      DateTime @default(now())

  @@index([fazendaId])
}

model AnimalLoteIatf {
  id          String   @id @default(cuid())
  loteId      String
  lote        LoteIatf @relation(fields: [loteId], references: [id], onDelete: Cascade)
  bovinoId    String
  bovino      Bovino   @relation(fields: [bovinoId], references: [id])

  @@index([loteId])
  @@index([bovinoId])
}
